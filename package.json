{
  "name": "workfolder",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "^4.1.8",
    "turbo": "2.9.11"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0"
    },
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "@tree-sitter-grammars/tree-sitter-yaml",
      "core-js-pure",
      "tree-sitter-json",
      "tree-sitter"
    ]
  }
}